class Solution:
    def prm(self,n):
        l=[1]*(n+1)
        
        cnt=1
        for i in range(3,int(n**0.5+1),2):
            if l[i]==1:
                for j in range(i*i ,n+1,2*i):
                    l[j]=0
        ans=[]
        ans.append(2)
        for i in range(3,n+1,2):
            if l[i]==1:
                ans.append(i)
        return ans
if __name__ == "__main__":
    s=Solution()
    n=int(input("Enter a number: "))
    print(s.prm(n))
