def totien(n):
    arr=[0]*(n+1)
    for i in range(n+1):
        arr[i]=i
    for i in range(2,n+1):
        if arr[i]==i:
            arr[i]=i-1
            for j in range(i,n+1,i):
                arr[j]=int((arr[j]/i)*(i-1))
    return arr[n]
if __name__=="__main__":
    print(totien(12))
    

